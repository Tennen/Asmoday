# Copy this file to `.env` for shared local defaults.
# Put machine-specific overrides in `.env.local`.

VISION_SERVICE_LOG_LEVEL=info
VISION_SERVICE_PORT=8081

VISION_SERVICE_MODEL_DIRECTORY=./models
VISION_SERVICE_MODEL_DEVICE=cpu
VISION_SERVICE_MODEL_CONFIDENCE_THRESHOLD=0.35

VISION_SERVICE_RTSP_TRANSPORT=tcp
VISION_SERVICE_RTSP_OPEN_TIMEOUT_MSEC=10000
VISION_SERVICE_RTSP_READ_TIMEOUT_MSEC=10000

VISION_SERVICE_ROI_ENABLED=false
VISION_SERVICE_YOLO_RUN_MODE=always
VISION_SERVICE_ROI_WARMUP_SECONDS=3.0
VISION_SERVICE_ROI_CLEAR_HOLD_SECONDS=1.0
